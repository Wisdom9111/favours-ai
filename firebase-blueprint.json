{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator of the portfolio",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "createdAt"]
    },
    "Profile": {
      "title": "Profile",
      "description": "Global profile data (hero text, summary)",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroDescription": { "type": "string" },
        "professionalSummary": { "type": "string" },
        "detailedProfileSummary": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["heroTitle", "heroSubtitle", "heroDescription", "professionalSummary", "detailedProfileSummary", "updatedAt"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the freelancer",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "description", "icon", "updatedAt"]
    },
    "Experience": {
      "title": "Experience",
      "description": "A professional experience entry",
      "type": "object",
      "properties": {
        "period": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["period", "role", "company", "location", "description", "updatedAt"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A skill tag",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "updatedAt"]
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Authorized administrators"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "Global settings for the portfolio. ID should be 'profile'."
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "Services listed on the profile"
    },
    "/experiences/{experienceId}": {
      "schema": { "$ref": "#/entities/Experience" },
      "description": "Experiences listed on the profile"
    },
    "/skills/{skillId}": {
      "schema": { "$ref": "#/entities/Skill" },
      "description": "Skills listed on the profile"
    }
  }
}