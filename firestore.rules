rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "wisdomezekiel28@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Site Content
    match /pageContent/{pageId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(pageId);
    }

    // Experiences
    match /experiences/{expId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(expId);
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(serviceId);
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidId(adminId);
    }
  }
}
